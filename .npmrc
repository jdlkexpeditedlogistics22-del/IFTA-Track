# Powered by OnSpace.AI
#
# WHY THIS FILE EXISTS
# --------------------
# The Android build failed compiling expo-modules-core with "cannot find
# symbol" for its ENTIRE compile classpath:
#
#     .../expo-modules-core/.../permissions/Permissions.java: error: cannot find symbol
#       import androidx.annotation.NonNull;              <- androidx missing
#     .../expo-modules-core/.../core/Promise.java:        error: package kotlin does not exist
#     .../expo-modules-core/.../ReactNativeHostHandler.java: package com.facebook.react.bridge does not exist
#       @NonNull final expo.modules.kotlin.Promise promise;  <- expo.modules.kotlin missing
#
# ROOT CAUSE
# ----------
# When EVERY basic dependency (androidx, kotlin, react-native bridge,
# expo.modules.kotlin) is unresolved for a single module, it is not a code
# problem — the module was compiled WITHOUT its dependency classpath. This is
# pnpm's default ISOLATED node_modules layout: packages live under
# node_modules/.pnpm/<name>@<ver>/ and are wired together with symlinks. Expo's
# Android autolinking and the Gradle native build cannot traverse that nested,
# symlinked layout to place each native module's transitive dependencies on the
# javac compile classpath, so expo-modules-core builds blind.
#
# FIX
# ---
# node-linker=hoisted makes pnpm write a FLAT, npm-style node_modules (real
# directories, no per-package symlink nesting), which is what React Native /
# Expo autolinking and Gradle expect. shamefully-hoist lifts transitive deps to
# the top level so any module resolving a peer/transitive dep (e.g.
# expo-modules-core -> kotlin-stdlib / androidx / react-native) finds it.
node-linker=hoisted
shamefully-hoist=true

# ALLOW RE-RESOLUTION SO THE expo-modules-core CAP ACTUALLY APPLIES
# -----------------------------------------------------------------
# The Android build keeps compiling expo-modules-core@2.5.0 (an Expo SDK 54
# build) into this SDK 53 project, so its ENTIRE Android compile classpath
# resolves to nothing:
#
#     .../expo-modules-core@2.5.0/.../Permissions.java: cannot find symbol
#       import androidx.annotation.NonNull;                 <- androidx missing
#     .../Promise.java: package kotlin does not exist
#       @NonNull final expo.modules.kotlin.Promise promise; <- expo.modules.kotlin missing
#     .../ReactNativeHostHandler.java: package com.facebook.react.bridge does not exist
#
# CRUCIAL: every OTHER native module in the build compiles fine (FROM-CACHE) —
# only expo-modules-core@2.5.0 fails. So this is a VERSION problem, not a layout
# problem. .pnpmfile.cjs already caps expo-modules-core to the SDK 53 line
# (>=2.4.0 <2.5.0), but that cap runs during dependency RESOLUTION. With the
# default frozen-lockfile behavior the build reuses the committed pnpm-lock.yaml
# — which still has 2.5.0 baked in from an earlier drift — so the cap never runs
# and 2.5.0 keeps getting installed.
#
# Setting prefer-frozen-lockfile=false lets pnpm re-resolve on the build server,
# which makes the .pnpmfile.cjs readPackage cap take effect and pull
# expo-modules-core back down to 2.4.x. The earlier drift that this same flag
# once caused happened ONLY because there was no cap yet; now the cap in
# .pnpmfile.cjs deterministically pins expo-modules-core (and codegen) on
# re-resolution, so re-resolving is safe and produces the SDK 53 graph.
prefer-frozen-lockfile=false

# CRUCIAL — WHY prefer-frozen-lockfile=false ALONE WAS NOT ENOUGH
# ---------------------------------------------------------------
# The build STILL compiled expo-modules-core@2.5.0. In a CI environment pnpm
# turns ON frozen-lockfile BY DEFAULT (it detects CI=true). frozen-lockfile
# takes precedence over prefer-frozen-lockfile: with it on, pnpm installs
# STRICTLY from the committed pnpm-lock.yaml (which still pins 2.5.0 from an
# earlier drift) and never runs dependency resolution — so the .pnpmfile.cjs
# cap on expo-modules-core never executes. Setting frozen-lockfile=false
# explicitly overrides the CI default, forcing pnpm to re-resolve so the cap
# (>=2.4.0 <2.5.0) actually applies and pulls expo-modules-core to the SDK 53
# line. This is the missing flag that keeps 2.5.0 from being reinstalled.
frozen-lockfile=false
strict-peer-dependencies=false
